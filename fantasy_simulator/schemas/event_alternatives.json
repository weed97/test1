{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EventAlternativesOutput",
  "type": "object",
  "required": ["alternatives", "recommended_id", "narrative_hint"],
  "additionalProperties": false,
  "properties": {
    "alternatives": {
      "type": "array",
      "minItems": 2,
      "maxItems": 4,
      "items": {
        "type": "object",
        "required": ["id", "summary", "risk"],
        "additionalProperties": false,
        "properties": {
          "id": {"type": "string"},
          "summary": {"type": "string"},
          "risk": {"type": "string", "enum": ["low", "medium", "high"]},
          "tone": {"type": "string"}
        }
      }
    },
    "recommended_id": {"type": "string"},
    "narrative_hint": {"type": "string"}
  }
}
