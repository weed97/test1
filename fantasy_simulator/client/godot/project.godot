; Engine configuration file.
; Godot 4.6+ — open this folder in Godot Editor and in Cursor.
config_version=5

[application]

config/name="CPoW XR"
config/description="CPoW simulation — OpenXR client; physics via Python API"
config/version="0.1.0"
run/main_scene="res://scenes/boot.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"
config/android_main_godot_project=true

[autoload]

ApiConfig="*res://scripts/net/api_config.gd"
ApiClient="*res://scripts/net/api_client.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/handheld/orientation=1

[rendering]

renderer/rendering_method="forward_plus"
textures/vram_compression/import_etc2_astc=true

[xr]

openxr/enabled=true
shaders/enabled=true
