type SrZone
    float center
    float top
    float bot
    int   touches
    int   bullBounce
    int   bearReject
    bool  isSupport
    float avgVol

var float[] pivotPrices = array.new_float()
var bool[]  pivotIsHigh  = array.new_bool()

ph = ta.pivothigh(high, pivotLeft, pivotRight)
pl = ta.pivotlow(low, pivotLeft, pivotRight)

if confirmed and not na(ph)
    array.push(pivotPrices, ph)
    array.push(pivotIsHigh, true)
if confirmed and not na(pl)
    array.push(pivotPrices, pl)
    array.push(pivotIsHigh, false)

while array.size(pivotPrices) > 50
    array.shift(pivotPrices)
    array.shift(pivotIsHigh)

f_buildZones() =>
    SrZone[] zones = array.new<SrZone>()
    float clusterR = atr14 * clusterAtrMult
    int pSize = array.size(pivotPrices)
    bool[] used = array.new_bool(pSize, false)
    for i = 0 to pSize - 1
        if not array.get(used, i)
            float pc = array.get(pivotPrices, i)
            bool isH = array.get(pivotIsHigh, i)
            float sumP = pc
            int cnt = 1
            int hiCnt = isH ? 1 : 0
            int loCnt = isH ? 0 : 1
            array.set(used, i, true)
            for j = i + 1 to pSize - 1
                if not array.get(used, j)
                    float pj = array.get(pivotPrices, j)
                    if math.abs(pj - pc) <= clusterR
                        sumP += pj
                        cnt += 1
                        if array.get(pivotIsHigh, j)
                            hiCnt += 1
                        else
                            loCnt += 1
                        array.set(used, j, true)
            float center = sumP / cnt
            float halfZ = atr14 * 0.3
            int tch = 0
            int bull = 0
            int bear = 0
            float tVol = 0.0
            for k = 0 to srLookback - 1
                if bar_index >= k
                    if high[k] >= center - halfZ and low[k] <= center + halfZ
                        tch += 1
                        tVol += volume[k]
                        bool bUp = false
                        bool bDn = false
                        for m = 0 to 2
                            if k - m >= 0
                                if close[k - m] > center + halfZ
                                    bUp := true
                                if close[k - m] < center - halfZ
                                    bDn := true
                        if bUp
                            bull += 1
                        if bDn
                            bear += 1
            float avgV = tch > 0 ? tVol / tch : 0.0
            bool sup = loCnt >= hiCnt
            SrZone z = SrZone.new(center, center + halfZ, center - halfZ, tch, bull, bear, sup, avgV)
            if tch >= minTouches
                array.push(zones, z)
    zones

SrZone[] srZones = f_buildZones()

float nearMajorSup = na
float nearMajorRes = na
float nearSupNet   = na
float nearResNet   = na
for z in srZones
    float netSup = z.touches > 0 ? z.bullBounce * 100.0 / z.touches : 0.0
    float netRes = z.touches > 0 ? z.bearReject * 100.0 / z.touches : 0.0
    bool majorSup = netSup >= 70 and z.touches >= 3 and z.avgVol > volMa * 2
    bool majorRes = netRes >= 70 and z.touches >= 3 and z.avgVol > volMa * 2
    if majorSup and z.center < close and (na(nearMajorSup) or z.center > nearMajorSup)
        nearMajorSup := z.center
        nearSupNet := netSup
    if majorRes and z.center > close and (na(nearMajorRes) or z.center < nearMajorRes)
        nearMajorRes := z.center
        nearResNet := netRes

var box[]   srBoxes  = array.new_box()
var label[] srLabels = array.new_label()
var line[]  distLines = array.new_line()
var label[] distLabels = array.new_label()

if barstate.islast
    for b in srBoxes
        box.delete(b)
    for l in srLabels
        label.delete(l)
    for ln in distLines
        line.delete(ln)
    for l in distLabels
        label.delete(l)
    array.clear(srBoxes)
    array.clear(srLabels)
    array.clear(distLines)
    array.clear(distLabels)

    SrZone[] supBelow = array.new<SrZone>()
    SrZone[] resAbove = array.new<SrZone>()

    for z in srZones
        float netSup = z.touches > 0 ? z.bullBounce * 100.0 / z.touches : 0.0
        float netRes = z.touches > 0 ? z.bearReject * 100.0 / z.touches : 0.0
        bool majorSup = netSup >= 70 and z.touches >= 3 and z.avgVol > volMa * 2
        bool minorSup = netSup >= 50 and z.touches >= 2 and not majorSup
        bool majorRes = netRes >= 70 and z.touches >= 3 and z.avgVol > volMa * 2
        bool minorRes = netRes >= 50 and z.touches >= 2 and not majorRes
        bool neutral  = netSup >= 40 and netSup <= 60 and not majorSup and not majorRes

        if showMajorOnly and not majorSup and not majorRes
            continue

        color bg = color.new(color.gray, 92)
        string txt = ""
        int bWidth = 1
        if majorSup and z.center < close
            bg := color.new(color.lime, 75)
            txt := "🟢 Major Support | 순지지: " + str.tostring(netSup, "#.#") + "% | Touches: " + str.tostring(z.touches)
            bWidth := 3
        else if minorSup and z.center < close
            bg := color.new(color.green, 88)
            txt := "Minor Support | 순지지: " + str.tostring(netSup, "#.#") + "%"
        else if majorRes and z.center > close
            bg := color.new(color.red, 75)
            txt := "🔴 Major Resistance | 순저항: " + str.tostring(netRes, "#.#") + "% | Touches: " + str.tostring(z.touches)
            bWidth := 3
        else if minorRes and z.center > close
            bg := color.new(color.red, 88)
            txt := "Minor Resistance | 순저항: " + str.tostring(netRes, "#.#") + "%"
        else if neutral
            bg := color.new(color.gray, 92)
            txt := "Neutral Zone | S: " + str.tostring(netSup, "#.#") + "% / R: " + str.tostring(netRes, "#.#") + "%"
        else
            continue

        box sb = box.new(bar_index - srLookback, z.top, bar_index + 30, z.bot,
             bgcolor=bg, border_width=bWidth)
        array.push(srBoxes, sb)
        label sl = label.new(bar_index + 5, z.center, txt, style=label.style_label_left,
             color=color.new(color.black, 50), textcolor=color.white, size=size.tiny)
        array.push(srLabels, sl)

        if z.center < close
            array.push(supBelow, z)
        else
            array.push(resAbove, z)

    if showDistLabels
        for n = 0 to 2
            float bestD = na
            float bestC = na
            int bestT = 0
            int bestB = 0
            for z in supBelow
                float d = (close - z.center) / close * 100.0
                if d > 0 and (na(bestD) or d < bestD)
                    bestD := d
                    bestC := z.center
                    bestT := z.touches
                    bestB := z.bullBounce
            if not na(bestC)
                float ns = bestT > 0 ? bestB * 100.0 / bestT : 0.0
                bool isMaj = ns >= 70 and bestT >= 3
                string dTxt = "↓ " + str.tostring(bestD, "#.##") + "% to " + (isMaj ? "Major" : "Minor") + " Support"
                line dl = line.new(bar_index, close, bar_index, bestC,
                     color=color.new(color.green, 30), style=line.style_dotted)
                label dll = label.new(bar_index + 2, (close + bestC) / 2, dTxt,
                     style=label.style_label_left, color=color.new(color.green, 60),
                     textcolor=color.white, size=isMaj ? size.small : size.tiny)
                array.push(distLines, dl)
                array.push(distLabels, dll)
                array.clear(supBelow)
                for z2 in srZones
                    if z2.center < close and z2.center != bestC
                        array.push(supBelow, z2)

        for n = 0 to 2
            float bestD = na
            float bestC = na
            int bestT = 0
            int bestBr = 0
            for z in resAbove
                float d = (z.center - close) / close * 100.0
                if d > 0 and (na(bestD) or d < bestD)
                    bestD := d
                    bestC := z.center
                    bestT := z.touches
                    bestBr := z.bearReject
            if not na(bestC)
                float nr = bestT > 0 ? bestBr * 100.0 / bestT : 0.0
                bool isMaj = nr >= 70 and bestT >= 3
                string dTxt = "↑ " + str.tostring(bestD, "#.##") + "% to " + (isMaj ? "Major" : "Minor") +
                     " Resistance (순저항 " + str.tostring(nr, "#.#") + "%)"
                line dl = line.new(bar_index, close, bar_index, bestC,
                     color=color.new(color.red, 30), style=line.style_dotted)
                label dll = label.new(bar_index + 2, (close + bestC) / 2, dTxt,
                     style=label.style_label_left, color=color.new(color.red, 60),
                     textcolor=color.white, size=isMaj ? size.small : size.tiny)
                array.push(distLines, dl)
                array.push(distLabels, dll)
                array.clear(resAbove)
                for z2 in srZones
                    if z2.center > close and z2.center != bestC
                        array.push(resAbove, z2)

f_wallSizeAt(float price, float pct) =>
    float sz = 0.0
    for w in walls
        if not w.broken and math.abs(w.level - price) / price * 100.0 < pct
            sz += w.vol / math.max(volMa, 1) * 50.0
    sz

f_obTag(float price, bool isAsk) =>
    string tag = ""
    if isAsk
        if f_wallNear(price, 0.3, false)
            tag += "SW🧱 "
        if not na(nearMajorRes) and math.abs(price - nearMajorRes) / price * 100.0 < 0.3
            tag += "MR🔴 "
        if math.abs(price - band2U) / price * 100.0 < 0.3
            tag += "V+2σ "
    else
        if f_wallNear(price, 0.3, true)
            tag += "BW🧱 "
        if not na(nearMajorSup) and math.abs(price - nearMajorSup) / price * 100.0 < 0.3
            tag += "MS🟢 "
        if math.abs(price - poc) / price * 100.0 < 0.3
            tag += "POC⭐ "
        if math.abs(price - band1D) / price * 100.0 < 0.3
            tag += "V-1σ "
    tag

float bidTotal = 0.0
float askTotal = 0.0
float imbRatio = 1.0
float spacing = atr14 * obAtrSpacing
for n = 1 to obLevels
    askTotal += f_wallSizeAt(close + spacing * n, 0.25)
    bidTotal += f_wallSizeAt(close - spacing * n, 0.25)
for w in walls
    if not w.broken
        if w.isBuy
            bidTotal += w.vol / math.max(volMa, 1) * 10.0
        else
            askTotal += w.vol / math.max(volMa, 1) * 10.0
imbRatio := askTotal > 0 ? bidTotal / askTotal : 1.0

f_sizeBar(float sz, float maxSz) =>
    int blocks = int(math.round(sz / math.max(maxSz, 1) * 8))
    string s = ""
    for i = 0 to 7
        s += i < blocks ? "█" : "░"
    s

var table obTable = na

tblPos(pos) =>
    pos == "top_left" ? position.top_left :
     pos == "bottom_right" ? position.bottom_right :
     pos == "bottom_left" ? position.bottom_left : position.top_right

tblSz(sz) =>
    sz == "tiny" ? size.tiny : sz == "normal" ? size.normal : size.small

if showOrderbook and barstate.islast
  if na(obTable)
    obTable := table.new(position.bottom_right, 4, 12, border_width=1)
  else
    table.clear(obTable, 0, 0, 3, 11)

  table.cell(obTable, 0, 0, "Price", bgcolor=color.gray, text_color=color.white, text_size=size.tiny)
  table.cell(obTable, 1, 0, "Wall", bgcolor=color.gray, text_color=color.white, text_size=size.tiny)
  table.cell(obTable, 2, 0, "Lvl", bgcolor=color.gray, text_color=color.white, text_size=size.tiny)
  table.cell(obTable, 3, 0, "Tag", bgcolor=color.gray, text_color=color.white, text_size=size.tiny)

  float maxSz = math.max(math.max(bidTotal, askTotal), 1.0)

  for n = obLevels to 1
    int row = obLevels - n + 1
    float askP = close + spacing * n
    float sz = f_wallSizeAt(askP, 0.25)
    string szTxt = sz > 0 ? "WALL 🧱" : "—"
    string bar = f_sizeBar(sz, maxSz)
    string tags = f_obTag(askP, true)
    bool highlight = sz > 0 or str.length(tags) > 0
    table.cell(obTable, 0, row, str.tostring(askP, format.mintick), bgcolor=color.new(color.red, highlight ? 20 : 60), text_size=size.tiny)
    table.cell(obTable, 1, row, szTxt + " " + bar, bgcolor=color.new(color.red, highlight ? 20 : 60), text_size=size.tiny)
    table.cell(obTable, 2, row, str.tostring(n), bgcolor=color.new(color.red, highlight ? 20 : 60), text_size=size.tiny)
    table.cell(obTable, 3, row, "ASK " + tags, bgcolor=color.new(color.red, highlight ? 20 : 60), text_size=size.tiny)

  table.cell(obTable, 0, 6, str.tostring(close, format.mintick), bgcolor=color.yellow, text_color=color.black, text_size=size.tiny)
  table.cell(obTable, 1, 6, "▶ CURRENT", bgcolor=color.yellow, text_color=color.black, text_size=size.tiny)
  table.cell(obTable, 2, 6, "—", bgcolor=color.yellow, text_color=color.black, text_size=size.tiny)
  table.cell(obTable, 3, 6, "캔들·벽 기반", bgcolor=color.yellow, text_color=color.black, text_size=size.tiny)

  for n = 1 to obLevels
    int row = 6 + n
    float bidP = close - spacing * n
    float sz = f_wallSizeAt(bidP, 0.25)
    string szTxt = sz > 0 ? "WALL 🧱" : "—"
    string bar = f_sizeBar(sz, maxSz)
    string tags = f_obTag(bidP, false)
    bool highlight = sz > 0 or str.length(tags) > 0
    table.cell(obTable, 0, row, str.tostring(bidP, format.mintick), bgcolor=color.new(color.green, highlight ? 20 : 60), text_size=size.tiny)
    table.cell(obTable, 1, row, szTxt + " " + bar, bgcolor=color.new(color.green, highlight ? 20 : 60), text_size=size.tiny)
    table.cell(obTable, 2, row, str.tostring(n), bgcolor=color.new(color.green, highlight ? 20 : 60), text_size=size.tiny)
    table.cell(obTable, 3, row, "BID " + tags, bgcolor=color.new(color.green, highlight ? 20 : 60), text_size=size.tiny)

  string imbTxt = imbRatio > 1.5 ? "📈 BID (" + str.tostring(imbRatio, "#.#") + "x)" :
       imbRatio < 0.67 ? "📉 ASK (" + str.tostring(imbRatio, "#.#") + "x)" : "⚖ BALANCED"
  color imbCol = imbRatio > 1.5 ? color.green : imbRatio < 0.67 ? color.red : color.gray
  table.cell(obTable, 0, 11, "Wall Imb", bgcolor=color.new(color.black, 30), text_size=size.tiny)
  table.cell(obTable, 1, 11, str.tostring(bidTotal, "#.#") + "/" + str.tostring(askTotal, "#.#"), bgcolor=color.new(color.black, 30), text_size=size.tiny)
  table.cell(obTable, 2, 11, imbTxt, bgcolor=color.new(imbCol, 50), text_color=color.white, text_size=size.tiny)
  table.cell(obTable, 3, 11, "FREE", bgcolor=color.new(color.black, 30), text_size=size.tiny)

f_distPct(float price) =>
    price > 0 ? (close - price) / price * 100.0 : 0.0

f_session() =>
    int h = hour(time, "UTC")
    h >= 0 and h < 8 ? "Asian" : h >= 8 and h < 16 ? "London" : h >= 16 and h < 22 ? "New York" : "Off-hours"

vwapSlope = sessionVwap - sessionVwap[5]
trendTxt  = vwapSlope > 0 ? "↑ Bullish VWAP" : vwapSlope < 0 ? "↓ Bearish VWAP" : "→ Flat VWAP"
volRatio  = volMa > 0 ? volume / volMa : 1.0
volRatioTxt = str.tostring(volRatio, "#.#") + "x" + (volRatio > 2.5 ? " 🔥" : "")

nearSupPct = not na(nearMajorSup) ? (close - nearMajorSup) / close * 100.0 : na
nearResPct = not na(nearMajorRes) ? (nearMajorRes - close) / close * 100.0 : na
priceNearSup = not na(nearMajorSup) and math.abs(close - nearMajorSup) / close * 100.0 < 1.5
priceNearRes = not na(nearMajorRes) and math.abs(nearMajorRes - close) / close * 100.0 < 1.5

longSetup  = close > sessionVwap and priceNearSup and imbRatio > 1.5 and volRatio > 2.0
shortSetup = close < sessionVwap and priceNearRes and imbRatio < 0.67 and volRatio > 2.0
signalTxt  = longSetup ? "LONG SETUP 🟢" : shortSetup ? "SHORT SETUP 🔴" : "NEUTRAL ⚪"

flipLong  = longSetup and not longSetup[1]
flipShort = shortSetup and not shortSetup[1]
var int lastEntryBar = na
barOK     = confirmed
coolOK    = na(lastEntryBar) or bar_index - lastEntryBar >= sigCoolBars
triggerLong  = flipLong and coolOK and barOK
triggerShort = flipShort and coolOK and barOK
if triggerLong or triggerShort
    lastEntryBar := bar_index

placeBuy  = ta.lowest(low, 5)
placeSell = ta.highest(high, 5)
plotshape(showMarks and triggerLong ? placeBuy : na, "Long", shape.triangleup, location.absolute, sigBull, size=size.tiny)
plotshape(showMarks and triggerShort ? placeSell : na, "Short", shape.triangledown, location.absolute, sigBear, size=size.tiny)
plotshape(showMarks and triggerLong ? placeBuy : na, "Long Glow", shape.triangleup, location.absolute, color.new(sigBull, 50), size=size.small)
plotshape(showMarks and triggerShort ? placeSell : na, "Short Glow", shape.triangledown, location.absolute, color.new(sigBear, 50), size=size.small)

var table dash = na
if showDashboard and barstate.islast
  if na(dash)
    dash := table.new(tblPos(dashPosition), 2, 16, border_width=1)
  else
    table.clear(dash, 0, 0, 1, 15)

  sz = tblSz(tableSize)
  vwapDist = f_distPct(sessionVwap)
  vwapArrow = vwapDist >= 0 ? "▲" : "▼"
  vwapCol = vwapDist >= 0 ? color.green : color.red

  table.cell(dash, 0, 0, "VWAP", text_size=sz, bgcolor=color.new(color.black, 30), text_color=color.white)
  table.cell(dash, 1, 0, str.tostring(sessionVwap, format.mintick) + " (" + str.tostring(vwapDist, "#.##") + "% " + vwapArrow + ")",
       text_size=sz, text_color=vwapCol)

  table.cell(dash, 0, 1, "W-VWAP", text_size=sz, bgcolor=color.new(color.black, 30), text_color=color.white)
  table.cell(dash, 1, 1, str.tostring(weeklyVwap, format.mintick) + " (" + str.tostring(f_distPct(weeklyVwap), "#.##") + "%)",
       text_size=sz)

  table.cell(dash, 0, 2, "M-VWAP", text_size=sz, bgcolor=color.new(color.black, 30), text_color=color.white)
  table.cell(dash, 1, 2, str.tostring(monthlyVwap, format.mintick) + " (" + str.tostring(f_distPct(monthlyVwap), "#.##") + "%)",
       text_size=sz)

  table.cell(dash, 0, 3, "POC", text_size=sz, bgcolor=color.new(color.black, 30), text_color=color.white)
  table.cell(dash, 1, 3, str.tostring(poc, format.mintick) + " " + str.tostring(pocDistPct, "#.##") + "% | " +
       pocStrengthLbl + " (" + str.tostring(pocStrength, "#.#") + "%)", text_size=sz, text_color=pocStrengthCol)

  table.cell(dash, 0, 4, "VAH", text_size=sz, bgcolor=color.new(color.black, 30), text_color=color.white)
  table.cell(dash, 1, 4, str.tostring(vah, format.mintick) + " (+" + str.tostring((vah - close) / close * 100.0, "#.##") + "% above)", text_size=sz)

  table.cell(dash, 0, 5, "VAL", text_size=sz, bgcolor=color.new(color.black, 30), text_color=color.white)
  table.cell(dash, 1, 5, str.tostring(val, format.mintick) + " (-" + str.tostring((close - val) / close * 100.0, "#.##") + "% below)", text_size=sz)

  table.cell(dash, 0, 6, "Buy Walls", text_size=sz, bgcolor=color.new(color.black, 30), text_color=color.white)
  table.cell(dash, 1, 6, str.tostring(activeBuyWalls) + " active | Nearest: " +
       (na(nearestBw) ? "—" : str.tostring(nearestBw, format.mintick)), text_size=sz, text_color=color.lime)

  table.cell(dash, 0, 7, "Sell Walls", text_size=sz, bgcolor=color.new(color.black, 30), text_color=color.white)
  table.cell(dash, 1, 7, str.tostring(activeSellWalls) + " active | Nearest: " +
       (na(nearestSw) ? "—" : str.tostring(nearestSw, format.mintick)), text_size=sz, text_color=color.red)

  table.cell(dash, 0, 8, "Major Sup", text_size=sz, bgcolor=color.new(color.black, 30), text_color=color.white)
  table.cell(dash, 1, 8, na(nearMajorSup) ? "—" : "↓" + str.tostring(nearSupPct, "#.##") + "% | 순지지 " +
       str.tostring(nearSupNet, "#.#") + "%", text_size=sz, text_color=color.lime)

  table.cell(dash, 0, 9, "Major Res", text_size=sz, bgcolor=color.new(color.black, 30), text_color=color.white)
  table.cell(dash, 1, 9, na(nearMajorRes) ? "—" : "↑" + str.tostring(nearResPct, "#.##") + "% | 순저항 " +
       str.tostring(nearResNet, "#.#") + "%", text_size=sz, text_color=color.red)

  table.cell(dash, 0, 10, "Vol Ratio", text_size=sz, bgcolor=color.new(color.black, 30), text_color=color.white)
  table.cell(dash, 1, 10, volRatioTxt, text_size=sz, text_color=volRatio > 2.5 ? color.orange : color.white)

  table.cell(dash, 0, 11, "Wall Imb", text_size=sz, bgcolor=color.new(color.black, 30), text_color=color.white)
  table.cell(dash, 1, 11, str.tostring(imbRatio, "#.##") + "x", text_size=sz,
       text_color=imbRatio > 1.5 ? color.green : imbRatio < 0.67 ? color.red : color.gray)

  table.cell(dash, 0, 12, "Session", text_size=sz, bgcolor=color.new(color.black, 30), text_color=color.white)
  table.cell(dash, 1, 12, f_session(), text_size=sz)

  table.cell(dash, 0, 13, "Trend", text_size=sz, bgcolor=color.new(color.black, 30), text_color=color.white)
  table.cell(dash, 1, 13, trendTxt, text_size=sz, text_color=vwapSlope >= 0 ? color.green : color.red)

  table.cell(dash, 0, 14, "ATR", text_size=sz, bgcolor=color.new(color.black, 30), text_color=color.white)
  table.cell(dash, 1, 14, str.tostring(atr14, format.mintick) + " (" + str.tostring(atr14 / close * 100.0, "#.##") + "%)", text_size=sz)

  table.cell(dash, 0, 15, "Signal", text_size=sz, bgcolor=color.new(color.black, 30), text_color=color.white)
  table.cell(dash, 1, 15, signalTxt, text_size=sz,
       text_color=longSetup ? color.lime : shortSetup ? color.red : color.gray)

crossAboveVwap = ta.crossover(close, sessionVwap)
crossBelowVwap = ta.crossunder(close, sessionVwap)
inPocZone      = math.abs(close - poc) <= atr14 * 0.3
buyWallDet     = buyCond
sellWallDet    = sellCond
inMajorSup     = not na(nearMajorSup) and low <= nearMajorSup + atr14 * 0.3 and high >= nearMajorSup - atr14 * 0.3
inMajorRes     = not na(nearMajorRes) and low <= nearMajorRes + atr14 * 0.3 and high >= nearMajorRes - atr14 * 0.3
strongBidImb   = imbRatio > 2.0
strongAskImb   = imbRatio < 0.5

alertcondition(crossAboveVwap,  "VWAP Cross Above",  "Price crossed above Session VWAP")
alertcondition(crossBelowVwap,  "VWAP Cross Below",  "Price crossed below Session VWAP")
alertcondition(inPocZone,       "POC Zone Entry",    "Price entered POC Zone")
alertcondition(buyWallDet,      "Buy Wall Detected", "Buy Wall detected")
alertcondition(sellWallDet,     "Sell Wall Detected","Sell Wall detected")
alertcondition(buyWallBroken,   "Buy Wall Broken",   "Buy Wall BROKEN")
alertcondition(sellWallBroken,  "Sell Wall Broken",  "Sell Wall BROKEN")
alertcondition(inMajorSup,      "Major Support",     "Price entered Major Support Zone")
alertcondition(inMajorRes,      "Major Resistance",  "Price entered Major Resistance Zone")
alertcondition(strongBidImb,    "Strong Bid Pressure","Bid/Ask imbalance > 2.0")
alertcondition(strongAskImb,    "Strong Ask Pressure","Bid/Ask imbalance < 0.5")
alertcondition(triggerLong,     "LONG SETUP",        "CPE: Composite LONG setup flip (confirmed bar)")
alertcondition(triggerShort,    "SHORT SETUP",       "CPE: Composite SHORT setup flip (confirmed bar)")
alertcondition(triggerLong or triggerShort, "Any Setup Signal", "CPE: New LONG or SHORT setup flip")

if confirmed
    if triggerLong
        alert("🟢 LONG  |  " + syminfo.ticker + " (" + timeframe.period + ")  VWAP+Sup+Imb+Vol", alert.freq_once_per_bar_close)
    if triggerShort
        alert("🔴 SHORT |  " + syminfo.ticker + " (" + timeframe.period + ")  VWAP+Res+Imb+Vol", alert.freq_once_per_bar_close)
    if crossAboveVwap
        alert("▲ VWAP Cross Above  |  " + syminfo.ticker + " (" + timeframe.period + ")", alert.freq_once_per_bar_close)
    if crossBelowVwap
        alert("▼ VWAP Cross Below  |  " + syminfo.ticker + " (" + timeframe.period + ")", alert.freq_once_per_bar_close)
