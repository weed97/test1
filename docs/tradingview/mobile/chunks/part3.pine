// ══════════ SECTION 2: VOLUME PROFILE + POC ══════════
// 2-1 Rolling Volume Profile — 롤링 거래량 프로파일
f_calcVP() =>
    float hi = ta.highest(high, vpLookback)
    float lo = ta.lowest(low, vpLookback)
    float step = (hi - lo) / vpBins
    float[] bins = array.new_float(vpBins, 0.0)
    float totalVol = 0.0
    for i = 0 to vpLookback - 1
        if bar_index >= i
            float c = close[i]
            float v = volume[i]
            int idx = step > 0 ? int(math.floor((c - lo) / step)) : 0
            idx := math.min(math.max(idx, 0), vpBins - 1)
            array.set(bins, idx, array.get(bins, idx) + v)
            totalVol += v
    // POC
    int pocIdx = 0
    float maxV = 0.0
    for j = 0 to vpBins - 1
        float bv = array.get(bins, j)
        if bv > maxV
            maxV := bv
            pocIdx := j
    float pocPrice = lo + step * (pocIdx + 0.5)
    // Value Area
    float vaVol = array.get(bins, pocIdx)
    int loIdx = pocIdx
    int hiIdx = pocIdx
    float target = totalVol * valueAreaPct / 100.0
    while vaVol < target and (loIdx > 0 or hiIdx < vpBins - 1)
        float volBelow = loIdx > 0 ? array.get(bins, loIdx - 1) : 0.0
        float volAbove = hiIdx < vpBins - 1 ? array.get(bins, hiIdx + 1) : 0.0
        if volAbove >= volBelow and hiIdx < vpBins - 1
            hiIdx += 1
            vaVol += array.get(bins, hiIdx)
        else if loIdx > 0
            loIdx -= 1
            vaVol += array.get(bins, loIdx)
        else if hiIdx < vpBins - 1
            hiIdx += 1
            vaVol += array.get(bins, hiIdx)
        else
            break
    float vah = lo + step * (hiIdx + 1)
    float val = lo + step * loIdx
    float pocStrength = totalVol > 0 ? maxV / totalVol * 100.0 : 0.0
    // HVN top 3 (excluding POC)
    int[] hvnIdx = array.new_int(3, -1)
    for rank = 0 to 2
        float best = 0.0
        int bestI = -1
        for j = 0 to vpBins - 1
            if j != pocIdx
                float bv = array.get(bins, j)
                bool already = false
                for r = 0 to rank - 1
                    if array.get(hvnIdx, r) == j
                        already := true
                if not already and bv > best
                    best := bv
                    bestI := j
        array.set(hvnIdx, rank, bestI)
    // LVN indices
    int[] lvnIdx = array.new_int()
    for j = 0 to vpBins - 1
        if j != pocIdx and array.get(bins, j) < maxV * 0.2
            array.push(lvnIdx, j)
    [pocPrice, vah, val, pocStrength, step, lo, bins, hvnIdx, lvnIdx, pocIdx]

[poc, vah, val, pocStrength, binStep, binLo, vpBinsArr, hvnIndices, lvnIndices, pocBinIdx] = f_calcVP()

pocDistPct = poc > 0 ? (close - poc) / poc * 100.0 : 0.0
pocDistUsd = close - poc
pocStrengthLbl = pocStrength > 15 ? "Strong POC" : pocStrength >= 8 ? "Medium POC" : "Weak POC"
pocStrengthCol = pocStrength > 15 ? #FFD700 : pocStrength >= 8 ? color.yellow : color.gray

// 2-2 POC / VAH / VAL lines — POC·VAH·VAL 라인
var line pocLine = na
var line vahLine = na
var line valLine = na
var label pocLbl = na
var label vahLbl = na
var label valLbl = na

if barstate.islast
    line.delete(pocLine)
    line.delete(vahLine)
    line.delete(valLine)
    label.delete(pocLbl)
    label.delete(vahLbl)
    label.delete(valLbl)
    int x1 = bar_index - vpLookback
    int x2 = bar_index + vpExtend
    pocLine := line.new(x1, poc, x2, poc, color=color.yellow, style=line.style_dashed, width=2)
    vahLine := line.new(x1, vah, x2, vah, color=color.green, style=line.style_dotted, width=1)
    valLine := line.new(x1, val, x2, val, color=color.red, style=line.style_dotted, width=1)
    pocLbl := label.new(x2, poc, "POC: " + str.tostring(poc, format.mintick), style=label.style_label_left,
         color=color.new(color.yellow, 50), textcolor=color.black, size=size.small)
    vahLbl := label.new(x2, vah, "VAH", style=label.style_label_left,
         color=color.new(color.green, 60), textcolor=color.white, size=size.tiny)
    valLbl := label.new(x2, val, "VAL", style=label.style_label_left,
         color=color.new(color.red, 60), textcolor=color.white, size=size.tiny)

// 2-3 POC Zone + HVN + LVN — POC 존·HVN·LVN
pocHalf = atr14 * 0.3
var box pocBox = na
var box[] hvnBoxes = array.new_box()
var label[] hvnLabels = array.new_label()
var line[] lvnLines = array.new_line()
var label[] lvnLabels = array.new_label()

if barstate.islast
    box.delete(pocBox)
    for b in hvnBoxes
        box.delete(b)
    for l in hvnLabels
        label.delete(l)
    for ln in lvnLines
        line.delete(ln)
    for l in lvnLabels
        label.delete(l)
    array.clear(hvnBoxes)
    array.clear(hvnLabels)
    array.clear(lvnLines)
    array.clear(lvnLabels)

    pocBox := box.new(bar_index - vpLookback, poc + pocHalf, bar_index + vpExtend, poc - pocHalf,
         bgcolor=color.new(color.yellow, 80), border_color=color.new(color.orange, 50),
         text="최고 거래 밀집 구간", text_size=size.tiny)

    if showHvn
        for rank = 0 to 2
            int hIdx = array.get(hvnIndices, rank)
            if hIdx >= 0
                float hPrice = binLo + binStep * (hIdx + 0.5)
                float hTop = binLo + binStep * (hIdx + 1)
                float hBot = binLo + binStep * hIdx
                box hb = box.new(bar_index - vpLookback, hTop, bar_index + vpExtend, hBot,
                     bgcolor=color.new(color.yellow, 85), border_width=0)
                array.push(hvnBoxes, hb)
                label hl = label.new(bar_index + vpExtend, hPrice, "HVN " + str.tostring(rank + 1),
                     style=label.style_label_left, color=color.new(color.yellow, 50),
                     textcolor=color.black, size=size.tiny)
                array.push(hvnLabels, hl)

    if showLvn
        int lvnCount = array.size(lvnIndices)
        int maxLvn = math.min(lvnCount, 8)
        for i = 0 to maxLvn - 1
            int lIdx = array.get(lvnIndices, i)
            float lPrice = binLo + binStep * (lIdx + 0.5)
            line ln = line.new(bar_index - vpLookback, lPrice, bar_index + vpExtend, lPrice,
                 color=color.gray, style=line.style_dashed, width=1)
            array.push(lvnLines, ln)
            if i < 3
                label ll = label.new(bar_index + vpExtend, lPrice, "LVN — Fast Move Zone",
                     style=label.style_label_left, color=color.new(color.gray, 60),
                     textcolor=color.white, size=size.tiny)
                array.push(lvnLabels, ll)

