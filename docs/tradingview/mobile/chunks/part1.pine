//@version=6
// ══════════════════════════════════════════════════════════════════════════════
// Crypto Precision Engine — VWAP · POC · Order Book · Support/Resistance Zones
// BTC/ETH 정밀 트레이딩 통합 인디케이터 (Pine Script v6)
// ══════════════════════════════════════════════════════════════════════════════
indicator(
     title="Crypto Precision Engine — VWAP · POC · Order Book · Support/Resistance Zones [BTC/ETH]",
     shorttitle="CPE Engine",
     overlay=true,
     behind_chart=false,
     precision=2,
     max_bars_back=2100,
     max_lines_count=500,
     max_labels_count=500,
     max_boxes_count=100)

// ══════════ SECTION 8: USER INPUTS ══════════
// ⚡ VWAP Settings / VWAP 설정
groupVwap   = "⚡ VWAP Settings"
showVwapBands    = input.bool(true,  "Show VWAP Bands",           group=groupVwap)
showWeeklyVwap   = input.bool(false, "Show Weekly VWAP",          group=groupVwap)
showMonthlyVwap  = input.bool(false, "Show Monthly VWAP",           group=groupVwap)
vwapBandMult     = input.float(1.0, "Band Multiplier", minval=0.1, step=0.1, group=groupVwap)
showVwapZones    = input.bool(true,  "Show VWAP S/R Zones",       group=groupVwap)
vwapZoneAtrMult  = input.float(0.5, "VWAP Zone ATR Mult", minval=0.1, step=0.1, group=groupVwap)
vwapZoneLookback = input.int(100,   "VWAP Zone Touch Lookback", minval=20, group=groupVwap)

// 📊 Volume Profile / POC / 거래량 프로파일
groupVp     = "📊 Volume Profile / POC"
vpLookback  = input.int(300,  "VP Lookback Bars", minval=50, maxval=500, group=groupVp)
vpBins      = input.int(48,   "VP Bins", minval=10, maxval=100, group=groupVp)
valueAreaPct= input.float(70.0,"Value Area %", minval=50, maxval=95, group=groupVp)
vpExtend    = input.int(50,    "Extend Lines Right (bars)", minval=0, group=groupVp)
showHvn     = input.bool(true, "Show HVN Zones", group=groupVp)
showLvn     = input.bool(true, "Show LVN Lines", group=groupVp)

// 🧱 Wall Detection / 매수·매도벽
groupWall   = "🧱 Wall Detection"
volMaLen    = input.int(20,   "Volume MA Length", minval=5, group=groupWall)
buyWallMult = input.float(2.5,"Buy Wall Multiplier", minval=1.0, step=0.1, group=groupWall)
sellWallMult= input.float(2.5,"Sell Wall Multiplier", minval=1.0, step=0.1, group=groupWall)
strongWallMult = input.float(5.0, "Strong Wall Mult", minval=2.0, step=0.5, group=groupWall)
modWallMult    = input.float(3.5, "Moderate Wall Mult", minval=2.0, step=0.5, group=groupWall)
wallExpiryBars = input.int(100,"Wall Expiry Bars", minval=10, group=groupWall)
wallZoneAtrMult= input.float(0.4,"Wall Zone ATR Mult", minval=0.1, step=0.1, group=groupWall)

// 🎯 Support / Resistance / 지지·저항 구간
groupSr     = "🎯 Support / Resistance Zones"
srLookback  = input.int(200,  "S/R Lookback", minval=50, group=groupSr)
pivotLeft   = input.int(10,   "Pivot Left", minval=2, group=groupSr)
pivotRight  = input.int(10,   "Pivot Right", minval=2, group=groupSr)
clusterAtrMult = input.float(0.5, "Cluster ATR Mult", minval=0.1, step=0.1, group=groupSr)
minTouches  = input.int(2,    "Min Touches", minval=1, group=groupSr)
showMajorOnly = input.bool(false, "Show Major Zones Only", group=groupSr)
showDistLabels= input.bool(true,  "Show Distance Labels", group=groupSr)

// 📖 Wall Pressure (무료·캔들 기반) / 실제 호가는 터미널 스크립트 사용
groupOb     = "📖 Wall Pressure (Free)"
showOrderbook = input.bool(false, "Show Wall Pressure Table", group=groupOb,
     tooltip="실제 오더북: python3 scripts/tradingview_orderbook_feed.py")
obLevels    = input.int(5, "Levels (each side)", minval=1, maxval=5, group=groupOb)
obAtrSpacing= input.float(0.15, "ATR Spacing", minval=0.05, step=0.05, group=groupOb)

// 📡 Signals / 진입 시그널
groupSig    = "📡 Signals"
showMarks   = input.bool(true, "Show Signal Markers", inline="sigshow", group=groupSig,
     tooltip="LONG/SHORT 플립 시점에만 차트 마커 표시 (확정봉·쿨다운 적용)")
sigCoolBars = input.int(5, "Signal Cooldown (bars)", minval=1, maxval=50, group=groupSig,
     tooltip="연속 시그널 방지 — 최소 대기 봉 수")
sigBull     = input.color(color.lime, "Long", inline="sigcol", group=groupSig)
sigBear     = input.color(color.red, "Short", inline="sigcol", group=groupSig)

// 🖥 Dashboard / 대시보드
groupDash   = "🖥 Dashboard"
showDashboard = input.bool(true, "Show Dashboard", group=groupDash)
dashPosition  = input.string("top_right", "Dashboard Position",
     options=["top_right", "top_left", "bottom_right", "bottom_left"], group=groupDash)
tableSize     = input.string("small", "Table Size",
     options=["tiny", "small", "normal"], group=groupDash)

// ══════════ SHARED CALCULATIONS ══════════
atr14   = ta.atr(14)
volMa   = ta.sma(volume, volMaLen)
volStd  = ta.stdev(volume, volMaLen)
confirmed = barstate.isconfirmed

// ══════════ SECTION 1: VWAP + BANDS ══════════
// 1-1 Session VWAP — 일일 세션 기준 VWAP
var float sCumVol  = 0.0
var float sCumPV   = 0.0
var float sSumDev  = 0.0
var float sSumDev2 = 0.0
var int   sBars    = 0

newDay = ta.change(time("1D")) != 0
if newDay
    sCumVol  := 0.0
    sCumPV   := 0.0
    sSumDev  := 0.0
    sSumDev2 := 0.0
    sBars    := 0

tp = hlc3
sCumVol  += volume
sCumPV   += tp * volume
sessionVwap = sCumVol > 0 ? sCumPV / sCumVol : tp

dev = close - sessionVwap
sSumDev  += dev
sSumDev2 += dev * dev
sBars    += 1
sessionStd = sBars > 1 ? math.sqrt(math.max((sSumDev2 - sSumDev * sSumDev / sBars) / (sBars - 1), 0.0)) : 0.0

band1U = sessionVwap + sessionStd * vwapBandMult
band2U = sessionVwap + sessionStd * 2.0 * vwapBandMult
band3U = sessionVwap + sessionStd * 3.0 * vwapBandMult
band1D = sessionVwap - sessionStd * vwapBandMult
band2D = sessionVwap - sessionStd * 2.0 * vwapBandMult
band3D = sessionVwap - sessionStd * 3.0 * vwapBandMult

vwapColor = close >= sessionVwap ? color.new(color.green, 0) : color.new(color.red, 0)
plot(sessionVwap, "Session VWAP", color=vwapColor, linewidth=2)

// 1-2 VWAP Standard Deviation Bands — 표준편차 밴드
pB1U = plot(showVwapBands ? band1U : na, "+1σ", color=color.new(color.blue, 40), linewidth=1)
pB1D = plot(showVwapBands ? band1D : na, "-1σ", color=color.new(color.blue, 40), linewidth=1)
plot(showVwapBands ? band2U : na, "+2σ", color=color.new(color.orange, 40), linewidth=1)
plot(showVwapBands ? band2D : na, "-2σ", color=color.new(color.orange, 40), linewidth=1)
plot(showVwapBands ? band3U : na, "+3σ", color=color.new(color.red, 20), linewidth=1)
plot(showVwapBands ? band3D : na, "-3σ", color=color.new(color.lime, 20), linewidth=1)
fill(pB1U, pB1D, color=color.new(color.blue, 90), title="±1σ Fill")

