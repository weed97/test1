[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scenes/main_menu.gd" id="1"]

[node name="MainMenu" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1")

[node name="VBox" type="VBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -280.0
offset_top = -220.0
offset_right = 280.0
offset_bottom = 220.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/separation = 10

[node name="Title" type="Label" parent="VBox"]
layout_mode = 2
text = "CPoW World Client"
horizontal_alignment = 1

[node name="Subtitle" type="Label" parent="VBox"]
layout_mode = 2
text = "유저 창조 에리어 — Eldoria /v1/turn 과 분리"
horizontal_alignment = 1

[node name="ServerLabel" type="Label" parent="VBox"]
layout_mode = 2
autowrap_mode = 3

[node name="UserEdit" type="LineEdit" parent="VBox"]
layout_mode = 2
placeholder_text = "creator_id (user_id)"

[node name="AreaNameEdit" type="LineEdit" parent="VBox"]
layout_mode = 2
placeholder_text = "새 에리어 이름"

[node name="AreaIdEdit" type="LineEdit" parent="VBox"]
layout_mode = 2
placeholder_text = "입장할 area_id"

[node name="HBox" type="HBoxContainer" parent="VBox"]
layout_mode = 2
alignment = 1
theme_override_constants/separation = 12

[node name="RefreshButton" type="Button" parent="VBox/HBox"]
layout_mode = 2
text = "목록"

[node name="FoundButton" type="Button" parent="VBox/HBox"]
layout_mode = 2
text = "개척"

[node name="EnterButton" type="Button" parent="VBox/HBox"]
layout_mode = 2
text = "입장 (3D)"

[node name="Log" type="RichTextLabel" parent="VBox"]
custom_minimum_size = Vector2(0, 180)
layout_mode = 2
size_flags_vertical = 3
scroll_active = true

[connection signal="pressed" from="VBox/HBox/RefreshButton" to="." method="_on_refresh_pressed"]
[connection signal="pressed" from="VBox/HBox/FoundButton" to="." method="_on_found_pressed"]
[connection signal="pressed" from="VBox/HBox/EnterButton" to="." method="_on_enter_pressed"]
[connection signal="text_submitted" from="VBox/UserEdit" to="." method="_on_user_edit_text_submitted"]
